# Environment variables for @obs/load-generator (ADR-002 §6.5).
# Base URL of the gateway under test.
GATEWAY_URL=http://localhost:8080
# Target request rate the scheduler aims to sustain.
TARGET_QPS=120
# How long the run lasts before printing the summary and exiting.
DURATION_SECONDS=300
# Per-request timeout (AbortSignal.timeout); abort/network failures bucket as `timeout`.
REQUEST_TIMEOUT_MS=15000
# Max in-flight requests at any moment.
CONCURRENCY=64

# --- Phase 6 chaos scheduler (`bun run chaos`) -------------------------------
# Control-plane URLs for the subject services whose faults the schedule drives.
MODEL_PROXY_URL=http://localhost:8083
RETRIEVER_URL=http://localhost:8082
# Schedule YAML (defaults to chaos/full.yaml). The demo uses chaos/demo.yaml.
#CHAOS_SCHEDULE=chaos/full.yaml
# Baseline traffic the scheduler sustains throughout the cycle.
CHAOS_TARGET_QPS=40
CHAOS_CONCURRENCY=32
