# Environment variables for agent-service.
# Copy to .env and fill in real values before running.

# Port the agent-service HTTP server listens on.
AGENT_SERVICE_PORT=8090

# PostgreSQL connection string.
DATABASE_URL=

# OpenTelemetry collector endpoint (OTLP/gRPC or OTLP/HTTP).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Grafana base URL.
GRAFANA_URL=http://localhost:3001

# Grafana Loki push URL.
LOKI_URL=

# Grafana Tempo URL.
TEMPO_URL=

# Grafana Mimir (Prometheus-compatible) URL.
MIMIR_URL=

# OpenLineage / Marquez API URL.
MARQUEZ_URL=
