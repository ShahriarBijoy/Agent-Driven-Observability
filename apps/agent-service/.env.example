# Environment variables for agent-service.
# Copy to .env and fill in real values before running on the host.
# Defaults in config.py already target host dev against the local compose stack,
# so a bare `uv run python -m agent_service` works once the stack is up.

# Port the agent-service HTTP server listens on.
AGENT_SERVICE_PORT=8093

# PostgreSQL connection string (host dev default shown).
DATABASE_URL=postgres://lab:lab@localhost:5432/observability_lab

# OpenTelemetry collector endpoint (OTLP/HTTP base; /v1/traces is appended).
# Leave blank on the host to skip exporting; set to http://localhost:4318 to
# ship agent traces to Alloy.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=agent-service

# Telemetry-plane read APIs the agent tools query (host-dev mapped ports).
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
TEMPO_URL=http://localhost:3200
MIMIR_URL=http://localhost:9009
MARQUEZ_URL=http://localhost:5000

# Claude model id for the agents. Blank => Agent SDK / Claude Code CLI default.
# The SDK authenticates against your local Claude Code session (no API key).
AGENT_MODEL=

# Filesystem roots the mutating agents are scoped to.
# RUNBOOKS_DIR: where runbook_read looks (repo-relative default).
RUNBOOKS_DIR=runbooks
# SUBJECT_REPO_DIR: a clone of the subject repo the auto-fixer edits + PRs.
SUBJECT_REPO_DIR=
# ARTIFACTS_DIR: where save_artifact also drops a file copy.
ARTIFACTS_DIR=.artifacts
# GRAFANA_DASHBOARDS_DIR: Grafana's file-provisioned dashboard JSONs. When the
# dashboard generator edits one of those dashboards the change is mirrored into
# its file here — otherwise the file provider reverts it within ~30s. Relative
# paths anchor at the repo root.
#GRAFANA_DASHBOARDS_DIR=infra/grafana/provisioning/dashboards

# Fixed dev tenant (mirrors the BFF, ADR-002).
DEV_TENANT=acme

# The local forge (PLAN-2 P9): Gitea on the VM. GITEA_TOKEN comes from
# `obs ci token`; without it the gitea_* tools report how to fix themselves
# and the auto-fixer falls back to the local dry-run remote.
GITEA_URL=http://obs-vm:3005
GITEA_TOKEN=
GITEA_REPO=obs/obs-lab

# Read-only cluster access for the rca agent's Bash/kubectl. Minted by
# `obs k8s agent-kubeconfig` (168h TTL); `obs agents` exports it automatically
# when the file exists, so set this only for raw `uv run` outside obs.
#KUBECONFIG=apps/agent-service/.kube/agent-ro.yaml

# Server-side-only cluster identity (PLAN-2 P11): CAN read Secrets, unlike
# the agent-ro kubeconfig above. Used only by the precheck battery's
# secret_age check via a fixed-argv kubectl subprocess — never handed to the
# model. Minted by a later task; until then the file is absent and the check
# reports "unavailable".
#K8S_REMEDIATE_KUBECONFIG=apps/agent-service/.kube/agent-remediate.yaml

# The lab's stand-in for a real secrets vault (PLAN-2 P11 Task 9):
# `obs fail stale-secret` rotates the in-cluster Postgres password and writes
# it here WITHOUT updating the K8s Secret; `update_db_secret` reads this file
# (never the model) to sync the Secret behind one approval. Missing file =
# "nothing to sync". Relative paths anchor at the repo root.
#VAULT_FILE=apps/agent-service/.secrets/db-vault.txt

# Shared secret required (as X-Obs-Token) on state-changing endpoints:
# POST /runs/:id/approve and PUT /settings. Unset = those endpoints are
# CLOSED (503) - the approval gate must not be LAN-bypassable (PLAN-2 P7).
# Keep in sync with the repo-root .env; `obs agents` injects it from there.
OBS_TOKEN=change-me

# Unified alert ingress (PLAN-2 P11): HMAC secret Grafana's webhook contact
# point signs /webhook/alerts payloads with (contact-points.yaml's
# hmacConfig.secret must match). Lab default, committed by convention (like
# lab/lab) — rotate it before running anywhere beyond the tailnet. Empty =
# signature verification is skipped (a startup warning is logged).
ALERT_WEBHOOK_SECRET=obs-lab-alert-hmac

# Reserved for the oncall debounce/verification watcher: minimum gap (seconds)
# between re-firings of the same alert before treating it as a fresh
# escalation, and the recheck cadence (minutes) after a proposed fix ships.
ONCALL_DEBOUNCE_SECONDS=90
ONCALL_VERIFY_MINUTES=10
