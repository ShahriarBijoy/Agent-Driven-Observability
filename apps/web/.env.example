# apps/web — all values have working local defaults; copy to .env to override.
# The dev server itself runs on :3003 (see package.json / vite.config.ts).

# Server-side (BFF)
#MIMIR_URL=http://localhost:9009
#DATABASE_URL=postgres://lab:lab@localhost:5432/observability_lab
#GATEWAY_URL=http://localhost:8080
#AGENT_SERVICE_URL=http://localhost:8090
#DEV_TOKEN=dev-local-token
#DEV_TENANT=acme

# Client-side (inlined into the bundle — never put secrets here)
#VITE_GRAFANA_URL=http://localhost:3001
#VITE_MARQUEZ_URL=http://localhost:3002
#VITE_OTLP_TRACES_URL=http://localhost:4318/v1/traces
