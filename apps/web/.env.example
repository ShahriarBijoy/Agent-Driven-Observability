# apps/web — all values have working local defaults; copy to .env to override.
# The dev server port comes from infra/ports.env (OBS_WEB_PORT, default 3003).
#
# Portless names: after `obs names`, the app is also https://obs-web.localhost.
# `obs web` / `obs all` auto-export the VITE_* vars below as https://obs-*
# names when the aliases are registered (an https page can't embed plain-http
# localhost iframes), so you normally never set them by hand.

# Server-side (BFF)
#MIMIR_URL=http://localhost:9009
#DATABASE_URL=postgres://lab:lab@localhost:5432/observability_lab
#GATEWAY_URL=http://localhost:8080
#AGENT_SERVICE_URL=http://localhost:8093
#DEV_TOKEN=dev-local-token
#DEV_TENANT=acme

# Client-side (inlined into the bundle — never put secrets here)
#VITE_GRAFANA_URL=http://localhost:3001
#VITE_MARQUEZ_URL=http://localhost:3002
#VITE_OTLP_TRACES_URL=http://localhost:4318/v1/traces
#VITE_OTLP_METRICS_URL=http://localhost:4318/v1/metrics
