# Environment variables for @obs/model-proxy — the mock LLM (Phase 1).
MODEL_PROXY_PORT=8083

# Master switch for fault injection. Set to false for a fully deterministic,
# never-erroring proxy (handy for local demos and tests).
FAULTS_ENABLED=true

# Per-request fault probabilities (fractions, e.g. 0.01 = 1%).
FAULT_P_500=0.01
FAULT_P_429=0.03
FAULT_P_STALL=0.01
STALL_MS=30000

# Gamma-distributed latency: base + Gamma(shape, scale_ms), capped at max.
LATENCY_BASE_MS=40
LATENCY_GAMMA_SHAPE=2.0
LATENCY_GAMMA_SCALE_MS=60
LATENCY_MAX_MS=4000

# Error clustering ("bad minute"): with this per-request probability, enter a
# degraded window of BAD_MINUTE_MS during which 500/429 rates are multiplied.
FAULT_P_BAD_MINUTE=0.002
BAD_MINUTE_MS=60000
BAD_MINUTE_MULTIPLIER=8
