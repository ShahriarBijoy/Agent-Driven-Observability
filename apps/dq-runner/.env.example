# Environment variables for dq-runner.
# Copy to .env and fill in real values before running.

# PostgreSQL connection string (reads the `inferences` table, writes `dq_violations`).
DATABASE_URL=postgres://lab:lab@localhost:5432/observability_lab

# Redis connection URL (used for a supplementary cache-size gauge).
REDIS_URL=redis://localhost:6379

# OpenTelemetry collector base endpoint (OTLP/HTTP). dq_* metrics are pushed here.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRIC_EXPORT_INTERVAL_MS=10000

# HTTP port for /health, /run and /violations.
DQ_RUNNER_PORT=8091

# How often (seconds) to run the data-quality check pass.
DQ_CHECK_INTERVAL_SECONDS=30

# --- Check thresholds (override to tune) ---
# Volume: violation when current/baseline ratio < LOW or > HIGH.
DQ_VOLUME_LOW=0.3
DQ_VOLUME_HIGH=3.0
# Drift: KS distance warn/high thresholds.
DQ_DRIFT_WARN=0.25
DQ_DRIFT_HIGH=0.4
# Freshness: stale when no inference for a tenant within this many seconds.
DQ_FRESHNESS_MAX_SECONDS=120
# Cache health: low-ratio violation below this (with enough samples).
DQ_CACHE_MIN_RATIO=0.05
