# Environment variables for dq-runner.
# Copy to .env and fill in real values before running.

# PostgreSQL connection string.
DATABASE_URL=

# Redis connection URL used for job queuing / deduplication.
REDIS_URL=

# OpenTelemetry collector endpoint (OTLP/gRPC or OTLP/HTTP).
OTEL_EXPORTER_OTLP_ENDPOINT=

# How often (in seconds) to execute the data-quality check loop.
DQ_CHECK_INTERVAL_SECONDS=30
