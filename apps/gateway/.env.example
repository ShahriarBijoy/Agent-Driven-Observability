# Environment variables for @obs/gateway (Phase 1).

# HTTP port the gateway listens on.
GATEWAY_PORT=8080

# Upstream service URLs (defaults are the in-cluster URLs).
EMBEDDER_URL=http://embedder:8081
RETRIEVER_URL=http://retriever:8082
MODEL_PROXY_URL=http://model-proxy:8083

# Shared timeout (ms) applied to every upstream call via AbortSignal.timeout.
UPSTREAM_TIMEOUT_MS=8000

# Redis backs the per-tenant token-bucket rate limiter (key rl:<tenant>).
# When unset, the gateway falls back to an in-memory limiter.
REDIS_URL=redis://redis:6379

# Postgres receives one usage_events row per successful chat.
# When unset, usage metering is a no-op.
DATABASE_URL=postgres://lab:lab@postgres:5432/observability_lab

# acme tenant token, surfaced for convenience (see the dev tenant registry).
DEV_TOKEN=dev-local-token

# Optional explicit backend selection (otherwise inferred from REDIS_URL/DATABASE_URL).
# RATE_LIMIT_BACKEND=redis
# USAGE_BACKEND=postgres
