{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "The cardinality guard for Phase 8's cluster telemetry. The k8s-monitoring chart gets a ~40-80k active-series budget inside Mimir's 100k max_global_series_per_user cap; allowlists (values.yaml metricsTuning) are what keep it honest. When the cap is hit, Mimir discards samples and the mimir-series-limit alert pages - this dashboard is where you see it coming instead.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "description": "Everything in the ingester head, against the hard 100k cap (infra/mimir/mimir.yaml max_global_series_per_user). Past the cap, new series are silently dropped and the mimir-series-limit alert fires.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100000,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80000 },
              { "color": "red", "value": 95000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(cortex_ingester_active_series)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Active series - Mimir total (cap 100k)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "description": "Series wearing the cluster=obs-lab external label - the Phase 8 addition this budget exists for. Orange from 60k, red at the 80k budget ceiling.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60000 },
              { "color": "red", "value": 80000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 5, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "count({cluster=\"obs-lab\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Cluster series (budget 40-80k)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "description": "Samples Mimir refused for series-limit reasons, 5m rate. Nonzero = the cap is being hit RIGHT NOW and data is being lost; this is the same signal the mimir-series-limit alert pages on.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          },
          "unit": "cps"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 5, "x": 11, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(rate(cortex_discarded_samples_total{reason=~\".*series.*\"}[5m])) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Series-limit discards",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "description": "Cluster telemetry vs everything else (the app/SLO/lineage plane). A sudden cluster jump means an allowlist regressed - check values.yaml metricsTuning before Mimir starts discarding.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "count({cluster=\"obs-lab\"})",
          "legendFormat": "cluster obs-lab",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "count({cluster!=\"obs-lab\", __name__=~\".+\"})",
          "legendFormat": "app / lab plane",
          "refId": "B"
        }
      ],
      "title": "Active series by origin (80k budget line)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "description": "Cluster series broken down by scrape job. The apiserver is the one to watch: un-allowlisted it shipped 36.8k series (93% of the cluster total) on day one - the keep-list in values.yaml holds it near ~4k.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 7 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "count by (job) ({cluster=\"obs-lab\"})",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Cluster series by job",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["kubernetes-mixin", "cardinality"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Mimir / Cardinality (K8s budget)",
  "uid": "k8s-cardinality",
  "version": 1,
  "weekStart": ""
}
