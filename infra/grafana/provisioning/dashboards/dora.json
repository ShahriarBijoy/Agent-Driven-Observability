{
  "uid": "cicd-dora",
  "title": "CI/CD \u00b7 Delivery",
  "description": "The delivery control plane as telemetry (PLAN-2 P9): pipeline health from ci-shim's metrics, DORA indicators computed from the lab's own events. No DevLake.",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["cicd", "dora"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "#73BF69",
        "name": "Deploys",
        "type": "tags",
        "tags": ["deployment"]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Pipeline health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Runs (window)",
      "description": "Completed pipeline runs in the dashboard time range.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(cicd_pipeline_runs_total[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failure rate",
      "description": "Share of pipeline runs in the window that did not succeed.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(increase(cicd_pipeline_runs_total{result!~\"success|skipped\"}[$__range])) / clamp_min(sum(increase(cicd_pipeline_runs_total[$__range])), 1)",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Run duration \u00b7 p95",
      "description": "95th percentile wall-clock pipeline duration over the window.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(increase(cicd_pipeline_run_duration_seconds_bucket[$__range])) by (le))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Oldest pending job",
      "description": "Live age of the oldest queued job. Climbing with zero completions = the runner is down (cicd-queue-stall).",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 180
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cicd_pipeline_oldest_pending_seconds",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Run duration percentiles",
      "description": "Over rolling 30m windows - CI events are sparse.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "auto",
            "spanNulls": true
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(increase(cicd_pipeline_run_duration_seconds_bucket[30m])) by (le))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum(increase(cicd_pipeline_run_duration_seconds_bucket[30m])) by (le))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Runs by result (30m windows)",
      "description": "Pipeline completions bucketed by conclusion.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 80,
            "showPoints": "auto",
            "spanNulls": true,
            "drawStyle": "bars",
            "barAlignment": 0
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (increase(cicd_pipeline_runs_total[30m]))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue",
      "description": "Queued-to-picked-up latency plus the live pending gauges the stall alert watches.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "auto",
            "spanNulls": true
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(increase(cicd_pipeline_queue_seconds_bucket[30m])) by (le))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "queue p95 (s)"
        },
        {
          "refId": "B",
          "expr": "cicd_pipeline_pending_jobs",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "pending jobs"
        },
        {
          "refId": "C",
          "expr": "cicd_pipeline_oldest_pending_seconds",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "oldest pending (s)"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CI plane liveness",
      "description": "Scrape health of the forge + shim across the tailnet, and shim emission failures.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "auto",
            "spanNulls": true
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"gitea\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "gitea up"
        },
        {
          "refId": "B",
          "expr": "up{job=\"cicd\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "ci-shim up"
        },
        {
          "refId": "C",
          "expr": "sum(increase(cicd_shim_errors_total[30m])) or vector(0)",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "shim emission errors (30m)"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "DORA",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Deployment frequency (window)",
      "description": "Deploys to the cluster in the dashboard range. Counted once per pipeline deploy (gateway ships in every deploy).",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 23
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(cicd_deployments_total{service=\"gateway\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Lead time \u00b7 p50",
      "description": "DORA lead time: commit timestamp to completed deploy, median over the window.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 23
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(increase(cicd_lead_time_seconds_bucket[$__range])) by (le))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Change failure rate",
      "description": "Approximation, honestly: % of deploys followed by an SLO fast-burn condition (the exact alert expressions) within 30 minutes. Evaluated on 30m subquery steps.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 23
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 15
              },
              {
                "color": "red",
                "value": 40
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(count_over_time(((sum(increase(cicd_deployments_total{service=\"gateway\"}[30m])) > bool 0) and on() (clamp_max((slo:gateway_availability:error_ratio5m > bool 0.0672) * (slo:gateway_availability:error_ratio1h > bool 0.0672) + (slo:gateway_latency:error_ratio5m > bool 0.672) * (slo:gateway_latency:error_ratio1h > bool 0.672), 1) == 1))[$__range:30m])) / clamp_min(sum(increase(cicd_deployments_total{service=\"gateway\"}[$__range])), 1)",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "MTTR (7d)",
      "description": "DORA time-to-restore: mean opened->resolved from the incidents table (agent-audit Postgres).",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "labpg"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 23
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "no resolved incidents",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "labpg"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT avg(extract(epoch from (resolved_at - opened_at))) AS mttr FROM incidents WHERE resolved_at IS NOT NULL AND opened_at > now() - interval '7 day'"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Deploys per day",
      "description": "Deployment frequency trend.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "fillOpacity": 80,
            "showPoints": "auto",
            "spanNulls": true,
            "drawStyle": "bars",
            "barAlignment": 0
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(cicd_deployments_total{service=\"gateway\"}[1d]))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "deploys/day"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Lead time trend",
      "description": "Median commit-to-deploy time, rolling daily window.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "auto",
            "spanNulls": true
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(increase(cicd_lead_time_seconds_bucket[1d])) by (le))",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "legendFormat": "p50 (1d window)"
        }
      ]
    }
  ]
}
