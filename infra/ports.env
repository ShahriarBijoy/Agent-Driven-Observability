# infra/ports.env - the lab's address book (PLAN-2 SS D).
#
# The ONLY place host-published port numbers live, Act I and Act II alike.
# Everything else substitutes from here: the compose files (via --env-file,
# wired into obs.ps1), obs.ps1 itself, the k3d config, the k8s overlays, and
# the `obs names` portless aliases. A collision with another project is a
# one-line edit here - nothing else references the number.
#
# Format: plain KEY=VALUE, # comments. Parseable by docker compose,
# PowerShell, and bash alike - keep it that way.

# --- human-facing endpoints (each gets an https://obs-*.localhost alias) ---
OBS_WEB_PORT=3003
OBS_GRAFANA_PORT=3001
OBS_GATEWAY_PORT=8080
OBS_AGENTS_PORT=8093
OBS_GITEA_PORT=3005
OBS_ARGOCD_PORT=8443
OBS_ROLLOUTS_PORT=3105
OBS_CHAOSMESH_PORT=2333
OBS_MARQUEZ_UI_PORT=3002
OBS_PYROSCOPE_PORT=4040
OBS_ALLOY_UI_PORT=12345
OBS_OTLP_HTTP_PORT=4318

# --- headless infra (env vars only, no alias - you never browse these) ---
OBS_OTLP_GRPC_PORT=4317
OBS_MIMIR_PORT=9009
OBS_LOKI_PORT=3100
OBS_TEMPO_PORT=3200
OBS_POSTGRES_PORT=5432
OBS_REDIS_PORT=6379
OBS_MARQUEZ_API_PORT=5000
OBS_MARQUEZ_ADMIN_PORT=5001
OBS_DQ_RUNNER_PORT=8091
OBS_EMBEDDER_PORT=8081
OBS_RETRIEVER_PORT=8082
OBS_MODEL_PROXY_PORT=8083
OBS_REGISTRY_PORT=5010
OBS_K3D_API_PORT=6550
OBS_GITEA_SSH_PORT=2222
OBS_CI_SHIM_PORT=8095

# --- machines (Profile A: cluster + CI on the VM; LGTM + agents local) ---
# Tailnet MagicDNS short names. Cluster egress targets the laptop by name;
# obs k8s wraps ssh to the VM by name. Ports above apply on whichever machine
# publishes the service.
OBS_VM_HOST=obs-vm
OBS_LAPTOP_HOST=shahriar

# 8090 is OFF-LIMITS: HyperHDR squats it on the host via a dual-stack bind.
# Never map anything onto it.
