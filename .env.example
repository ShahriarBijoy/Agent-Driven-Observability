# ── Postgres (pgvector) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lab
POSTGRES_PASSWORD=lab
POSTGRES_DB=observability_lab
DATABASE_URL=postgres://lab:lab@localhost:5432/observability_lab

# ── Redis (embedding cache + rate-limit) ──
REDIS_URL=redis://localhost:6379

# ── OpenTelemetry ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=
OTEL_LOG_LEVEL=info

# ── OpenLineage / Marquez ──
MARQUEZ_URL=http://localhost:5000
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=observability-lab

# ── Service ports ──
GATEWAY_PORT=8080
EMBEDDER_PORT=8081
RETRIEVER_PORT=8082
MODEL_PROXY_PORT=8083
AGENT_SERVICE_PORT=8090
WEB_PORT=3000
GRAFANA_PORT=3001
MARQUEZ_WEB_PORT=3002

# ── Dev auth (local only) ──
DEV_TENANT=acme
DEV_TOKEN=dev-local-token
