{
  "name": "ai-observability-lab",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "load:start": "bun --cwd apps/load-generator run start",
    "chaos:run": "bun --cwd apps/load-generator run chaos",
    "demo:incident": "bash scripts/demo-incident.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "oxfmt": "0.52.0",
    "oxlint": "^1.67.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8"
}
